# URL del backend desplegado en Render (ej: https://backend-coaching-platform.onrender.com)
VITE_BACKEND_URL=

# URL del proyecto Supabase — se encuentra en Settings > API > Project URL
VITE_SUPABASE_URL=

# Clave pública (anon/publishable) de Supabase — Settings > API > Project API keys
# Es seguro exponerla en el cliente; RLS controla el acceso a los datos
VITE_SUPABASE_ANON_KEY=
