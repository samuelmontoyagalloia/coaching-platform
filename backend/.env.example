# Transaction pooler — para queries de la app (IPv4, pgbouncer)
# Formato: postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

# Session pooler — para migraciones de Prisma (requiere conexión directa)
# Formato: postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres
DIRECT_URL=

# URL base del proyecto Supabase — Settings > API > Project URL
SUPABASE_URL=

# Clave service_role — Settings > API > Project API keys (NUNCA exponer en cliente)
SUPABASE_SERVICE_KEY=

# Secreto para firmar JWT — genera uno con: openssl rand -base64 64
JWT_SECRET=

# Puerto del servidor Express
PORT=3001

# URL del frontend para CORS
FRONTEND_URL=http://localhost:5173
