generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id                  String         @id @default(uuid()) @db.Uuid
  name                String
  email               String         @unique
  ikigai_summary      String?
  business_idea       String?
  offer_summary       String?
  coaching_start_date DateTime?
  status              String         @default("active")
  created_at          DateTime       @default(now())
  sessions            Session[]
  plan_tasks          PlanTask[]
  daily_usage         DailyUsage[]
  subscriptions       Subscription[]
  users               User[]
  session_chunks      SessionChunk[]

  @@map("clients")
}

model Session {
  id             String         @id @default(uuid()) @db.Uuid
  client_id      String         @db.Uuid
  session_number Int
  fecha          DateTime
  tipo           String         @default("Formal")
  notas_clave    String?
  resumen_ia     String?
  transcripcion  String?
  grabacion_url  String?
  created_at     DateTime       @default(now())
  client         Client         @relation(fields: [client_id], references: [id], onDelete: Cascade)
  session_chunks SessionChunk[]

  @@map("sessions")
}

model SessionChunk {
  id         String   @id @default(uuid()) @db.Uuid
  client_id  String   @db.Uuid
  session_id String   @db.Uuid
  chunk_text String
  created_at DateTime @default(now())
  client     Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  session    Session  @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@map("session_chunks")
}

model PlanTask {
  id           String    @id @default(uuid()) @db.Uuid
  client_id    String    @db.Uuid
  day_number   Int
  description  String
  completed    Boolean   @default(false)
  completed_at DateTime?
  created_at   DateTime  @default(now())
  client       Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@map("plan_tasks")
}

model DailyUsage {
  id              String   @id @default(uuid()) @db.Uuid
  client_id       String   @db.Uuid
  date            DateTime @db.Date
  messages_used   Int      @default(0)
  tasks_completed Int      @default(0)
  created_at      DateTime @default(now())
  client          Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@unique([client_id, date])
  @@map("daily_usage")
}

model Subscription {
  id                String    @id @default(uuid()) @db.Uuid
  client_id         String    @db.Uuid
  status            String    @default("trial")
  plan              String    @default("basic")
  price_usd         Decimal   @db.Decimal(10, 2)
  wompi_token       String?
  next_billing_date DateTime?
  created_at        DateTime  @default(now())
  client            Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model User {
  id         String    @id @default(uuid()) @db.Uuid
  email      String    @unique
  name       String?
  photo_url  String?
  client_id  String?   @db.Uuid
  role       String    @default("client")
  created_at DateTime  @default(now())
  client     Client?   @relation(fields: [client_id], references: [id], onDelete: SetNull)
  passkeys   Passkey[]

  @@map("users")
}

model Passkey {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String   @db.Uuid
  credential_id String   @unique
  public_key    String
  counter       BigInt   @default(0)
  device_type   String?
  backed_up     Boolean  @default(false)
  transports    String?
  created_at    DateTime @default(now())
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("passkeys")
}
